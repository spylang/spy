from __spy__ import _stdout_write


@blue.generic
def print1(T):
    """
    print a single item and a space
    """

    def p(x: T) -> None:
        _stdout_write(str(x))
        _stdout_write(" ")

    return p


@blue.generic
def println(T):
    """
    print a single item and a newline
    """

    def p(x: T) -> None:
        _stdout_write(str(x))
        _stdout_write("\n")

    return p
