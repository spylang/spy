"""
Things to notice:
  - `main()` can take `argv` as a `list[str]` and can return an `i32` exit code
  - the exit code is propagated to the OS
  - `argv` contains the script/executable name and the script arguments
"""

def main(argv: list[str]) -> i32:
    print("argv:")
    for arg in argv:
        print(arg)
    print("exit code: 88")
    return 88
