@blue.generic
def add(T):
    def impl(x: T, y: T) -> T:
        return x + y

    return impl


# or (just syntactic sugar)


def add2[T](x: T, y: T) -> T:
    return x + y


def main() -> None:
    print(add[i32](1, 2))
    print(add[str]("hello ", "world"))

    print(add2[i32](1, 2))
    print(add2[str]("hello ", "world"))
