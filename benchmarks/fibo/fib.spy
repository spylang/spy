from time import time


def fib(n: i32) -> i32:
    if n < 2:
        return n
    else:
        return fib(n - 1) + fib(n - 2)


def main() -> None:
    t0 = time()
    ans = fib(40)
    t1 = time()
    assert ans == 102334155
    print("Computed fib(40) = ", ans)
    print("# in ", t1 - t0, "seconds.")
